{
  "openapi": "3.0.0",
  "info": {
    "title": "Health Check API",
    "version": "1.0.0"
  },

  "security": [
    {
      "bearerAuth": [],
      "clientId": []
    }
  ],

  "paths": {
    "/api/health/check": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check endpoint",
        "description": "Public endpoint - no authentication required. Returns the health status of the API.",
        "security": [],
        "responses": {
          "200": {
            "description": "API is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponse"
                },
                "example": {
                  "status": "UP"
                }
              }
            }
          }
        }
      }
    }
  },

  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "clientId": {
        "type": "apiKey",
        "in": "header",
        "name": "x-client-id"
      }
    },

    "schemas": {
      "HealthCheckResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["UP", "DOWN"],
            "description": "Health status of the API"
          }
        },
        "required": ["status"]
      }
    }
  }
}
