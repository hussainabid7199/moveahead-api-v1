{
  "openapi": "3.0.0",
  "info": {
    "title": "Department API",
    "version": "1.0.0"
  },

  "security": [
    {
      "bearerAuth": [],
      "clientId": []
    }
  ],

  "paths": {
    "/api/department/{companyId}": {
      "get": {
        "tags": ["Department"],
        "summary": "Get all departments by company ID",
        "description": "Requires authentication. All roles can access. SuperAdmin receives a count only. Optionally filter by branchId and include nested children.",
        "parameters": [
          {
            "name": "companyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Company ID"
          },
          {
            "name": "branchId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Optional branch ID to filter departments"
          },
          {
            "name": "includeChildren",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "If true, each top-level department includes its sub-departments"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query for department name"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of results per page"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Departments fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/DepartmentListResponse"
                    },
                    {
                      "$ref": "#/components/schemas/DepartmentCountResponse"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - Insufficient permissions"
          },
          "404": {
            "description": "Company not found"
          }
        }
      },
      "post": {
        "tags": ["Department"],
        "summary": "Create a new department",
        "description": "Requires authentication. Roles: ADMINISTRATOR only.",
        "parameters": [
          {
            "name": "companyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Company ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DepartmentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Department created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepartmentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - Insufficient permissions"
          }
        }
      }
    },

    "/api/department/{companyId}/{id}": {
      "get": {
        "tags": ["Department"],
        "summary": "Get a department by ID",
        "description": "Requires authentication. All roles can access. Always returns nested children.",
        "parameters": [
          {
            "name": "companyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Company ID"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Department ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Department fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepartmentResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - Insufficient permissions"
          },
          "404": {
            "description": "Department not found"
          }
        }
      },
      "put": {
        "tags": ["Department"],
        "summary": "Update a department",
        "description": "Requires authentication. Roles: ADMINISTRATOR only.",
        "parameters": [
          {
            "name": "companyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Company ID"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Department ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DepartmentUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Department updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepartmentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - Insufficient permissions"
          },
          "404": {
            "description": "Department not found"
          }
        }
      }
    }
  },

  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "clientId": {
        "type": "apiKey",
        "in": "header",
        "name": "x-client-id"
      }
    },

    "schemas": {
      "DepartmentRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "Cardiology"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "nullable": true,
            "example": "Handles all cardiac-related cases"
          },
          "parentId": {
            "type": "string",
            "nullable": true,
            "example": null,
            "description": "ID of the parent department for sub-departments"
          },
          "branchId": {
            "type": "string",
            "nullable": true,
            "example": null,
            "description": "Optional branch this department belongs to"
          }
        }
      },

      "DepartmentUpdateRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "Cardiology"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "nullable": true,
            "example": "Handles all cardiac-related cases"
          },
          "parentId": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "branchId": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "isActive": {
            "type": "boolean",
            "example": true
          }
        }
      },

      "DepartmentDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "parentId": {
            "type": "string",
            "nullable": true
          },
          "companyId": {
            "type": "string"
          },
          "branchId": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "isActive": {
            "type": "boolean"
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DepartmentDto"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },

      "DepartmentResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/DepartmentDto"
          }
        }
      },

      "DepartmentListResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DepartmentDto"
            }
          }
        }
      },

      "DepartmentCountResponse": {
        "type": "object",
        "description": "Returned to SuperAdmin role — count only",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "count": {
                "type": "integer",
                "example": 12
              }
            }
          }
        }
      }
    }
  }
}
