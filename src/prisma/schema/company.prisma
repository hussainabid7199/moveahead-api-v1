model Company {
    id         String  @id @default(cuid()) @map("id") @db.VarChar(191) // UUID or cuid for unique company ID
    parentId   String? @map("parent_id") @db.VarChar(191) // For hierarchical company structure
    name       String  @map("name") @db.VarChar(200)
    website    String? @map("website") @db.VarChar(2048)
    isVerified Boolean @default(false) @map("is_verified")

    isActive  Boolean   @default(true) @map("is_active")
    // Timestamps
    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
    updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

    // Relations
    branches      Branch[]
    userCompanyBranch UserCompanyBranch[]
    userCompany UserCompany[]

    // Indexes for performance
    @@index([name(200)], name: "idx_company_name")
    @@index([isActive, createdAt], name: "idx_company_active_created")
    @@map("company")
}

model Branch {
    id          String  @id @default(cuid()) @map("id") @db.VarChar(191) // UUID or cuid for unique branch ID
    companyId   String  @map("company_id") @db.VarChar(191) //
    parentId    String? @map("parent_id") @db.VarChar(191) // For hierarchical branch structure
    name        String  @map("name") @db.VarChar(200)
    address     String? @map("address") @db.VarChar(500)
    phoneNumber String? @map("phone_number") @db.VarChar(20) // E.164 format
    latitude    Float?  @map("latitude")
    longitude   Float?  @map("longitude")
    isActive    Boolean @default(true) @map("is_active")

    // Timestamps
    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
    updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

    userCompanyBranch UserCompanyBranch[]

    // Relations
    company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    // Indexes for performance
    @@index([name(200)], name: "idx_branch_name")
    @@index([isActive, createdAt], name: "idx_branch_active_created")
    @@map("branch")
}

model UserCompanyBranch {
    userId   String @map("user_id") @db.VarChar(191) // UUID or cuid for unique user ID
    companyId String @map("company_id") @db.VarChar(191) // UUID or cuid for unique company ID
    branchId String @map("branch_id") @db.VarChar(191) // UUID or cuid for unique branch ID

    // Relations with cascade delete
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
    branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

    @@id([userId, companyId, branchId])
    @@index([userId], name: "idx_user_branch_user_id")
    @@index([companyId], name: "idx_user_branch_company_id")
    @@index([branchId], name: "idx_user_branch_branch_id")
    @@map("user_company_branch")
}

model UserCompany {
    userId   String @map("user_id") @db.VarChar(191) // UUID or cuid for unique user ID
    companyId String @map("company_id") @db.VarChar(191) // UUID or cuid for unique company ID

    // Relations with cascade delete
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    @@id([userId, companyId])
    @@index([userId], name: "idx_user_company_user_id")
    @@index([companyId], name: "idx_user_company_company_id")
    @@map("user_company")
}
