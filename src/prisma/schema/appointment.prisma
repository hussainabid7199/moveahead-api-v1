model Appointment {
    id              String @id @default(cuid()) @map("id") @db.VarChar(191)
    userId          String @map("user_id") @db.VarChar(191)
    doctorProfileId String @map("doctor_profile_id") @db.VarChar(191)
    locationId      String @map("location_id") @db.VarChar(191)
    serviceId       String @map("service_id") @db.VarChar(191)

    appointmentDate DateTime @map("appointment_date") @db.Timestamp(6)
    status          String?  @map("status") @db.VarChar(100)

    isActive Boolean @default(true) @map("is_active")

    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
    updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

    //Relations
    user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
    location      Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
    service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    doctorRating    DoctorRating[]
    bookAppointment BookAppointment[]
    payment         Payment[]

    @@index([status(100)], name: "idx_appointment_status")
    @@index([appointmentDate(20)], name: "idx_appointment_date")
    @@map("appointments")
}

model BookAppointment {
    id            String @id @default(cuid()) @map("id") @db.VarChar(191)
    doctorId      String @map("doctor_id") @db.VarChar(191)
    locationId    String @map("location_id") @db.VarChar(191)
    appointmentId String @map("appointment_id") @db.VarChar(191)

    date      DateTime @map("date") @db.Timestamp(6)
    day       String?  @map("day") @db.VarChar(50)
    startTime String?  @map("start_time") @db.VarChar(50)
    endTime   String?  @map("end_time") @db.VarChar(50)
    status    String?  @map("status") @db.VarChar(100)

    isActive Boolean @default(true) @map("is_active")

    createdAt DateTime  @default(now()) @map("created_at")@db.Timestamp(6)
    updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

    //Relations
    doctor      User        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
    location    Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
    appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

    @@index([status(100)], name: "idx_appointment_status")
    @@map("book_appointments")
}

model AppointmentSlot {
    id         String @id @default(cuid()) @map("id") @db.VarChar(191)
    doctorId   String @map("doctor_id") @db.VarChar(191)
    locationId String @map("location_id") @db.VarChar(191)

    day       String? @map("day") @db.VarChar(50)
    startTime String? @map("start_time") @db.VarChar(50)
    endTime   String? @map("end_time") @db.VarChar(50)

    appointmentSlotDuration Int? @map("appointment_slot_duration") @db.Int
    totalAppointmentSlots   Int? @map("total_appointment_slots") @db.Int

    isActive Boolean @default(true) @map("is_active")

    createdAt DateTime  @default(now()) @map("created_at")  @db.Timestamp(6)
    updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

    //Relations
    doctor   User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
    location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

    @@index([appointmentSlotDuration], name: "idx_appointment_slot_duration")
    @@index([totalAppointmentSlots], name: "idx_total_appointment_slots")
    @@map("appointment_slots")
}

model Location {
    id       String  @id @default(cuid()) @map("id") @db.VarChar(191)
    doctorId String  @map("doctor_id") @db.VarChar(191)
    name     String  @map("name") @db.VarChar(100)
    address  String? @map("address") @db.VarChar(255)
    city     String? @map("city") @db.VarChar(100)
    state    String? @map("state") @db.VarChar(100)
    country  String? @map("country") @db.VarChar(100)
    zipCode  String? @map("zip_code") @db.VarChar(20)
    phone    String? @map("phone") @db.VarChar(20)

    isLocationVerified Boolean @default(false) @map("is_location_verified")
    verifiedBy         String? @map("verified_by") @db.VarChar(191)

    isActive Boolean @default(true) @map("is_active")

    createdAt DateTime  @default(now()) @map("created_at")   @db.Timestamp(6)
    updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

    //Relations
    doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)

    appointment     Appointment[]
    bookAppointment BookAppointment[]
    appointmentSlot AppointmentSlot[]
    service         Service[]

    @@index([isActive, createdAt], name: "idx_location_active_created")
    @@map("locations")
}

model Service {
    id         String @id @default(cuid()) @map("id") @db.VarChar(191)
    doctorId   String @map("doctor_id") @db.VarChar(191)
    locationId String @map("location_id") @db.VarChar(191)

    name        String  @unique @map("name") @db.VarChar(100)
    description String? @map("description") @db.VarChar(300)
    price      Decimal @map("price") @db.Decimal(10, 2)

    isActive Boolean @default(true) @map("is_active")

    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
    updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

    //Relations
    doctor   User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
    location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

    appointment Appointment[]

    @@index([isActive, createdAt], name: "idx_appointment_active_created")
    @@map("service")
}

model Payment {
    id            String  @id @default(cuid()) @map("id") @db.VarChar(191)
    appointmentId String  @map("appointment_id") @db.VarChar(191)
    transactionId String? @map("transaction_id") @db.VarChar(191)

    amount Decimal @map("amount") @db.Decimal(10, 2)
    status String  @map("status") @db.VarChar(100)

    paymentMethod String  @map("payment_method") @db.VarChar(100)
    currencyCode  String? @map("currency_code") @db.VarChar(10)

    isActive Boolean @default(true) @map("is_active")

    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
    updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

    //Relations
    appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

    @@index([amount(100)], name: "idx_users_payment_amount")
    @@index([status(100)], name: "idx_users_payment_status")
    @@index([paymentMethod(100)], name: "idx_users_payment_method")
    @@index([isActive, createdAt], name: "idx_users_active_created")
    @@map("payments")
}
