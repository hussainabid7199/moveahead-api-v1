model DoctorProfile {
    id             String    @id @default(cuid()) @map("id") @db.VarChar(191)
    userId         String    @map("user_id") @db.VarChar(191)
    name           String    @map("name") @db.VarChar(200)
    email          String    @map("email") @db.VarChar(200)
    specialization String?   @map("specialization") @db.VarChar(200)
    bio            String?   @map("bio") @db.VarChar(500)
    website        String?   @map("website") @db.VarChar(200)
    overallRating  Int?      @map("overall_rating") @db.Int
    createdAt      DateTime  @default(now()) @map("created_at")
    updatedAt      DateTime? @updatedAt @map("updated_at")
    isActive       Boolean   @default(true) @map("is_active")

    doctorService     DoctorService[]
    doctorRating      DoctorRating[]
    doctorLocation    DoctorServiceLocation[]
    doctorAppointment DoctorAppointment[]

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([name], name: "idx_doctor_profile_name")
    @@index([email], name: "idx_doctor_profile_email")
    @@index([overallRating], name: "idx_doctor_profile_overall_rating")
    @@index([isActive, createdAt], name: "idx_doctor_profile_active_created")
    @@map("doctor_profiles")
}

model DoctorService {
    id              String    @id @default(cuid()) @map("id") @db.VarChar(191)
    doctorProfileId String    @map("doctor_profile_id") @db.VarChar(191)
    name            String    @map("name") @db.VarChar(100)
    createdAt       DateTime  @default(now()) @map("created_at")
    updatedAt       DateTime? @updatedAt @map("updated_at")
    isActive        Boolean   @default(true) @map("is_active")

    doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

    @@index([name], name: "idx_doctor_service_name")
    @@index([isActive, createdAt], name: "idx_doctor_service_active_created")
    @@map("doctor_services")
}

model DoctorRating {
    id              String    @id @default(cuid()) @map("id") @db.VarChar(191)
    doctorProfileId String    @map("doctor_profile_id") @db.VarChar(191)
    review          String    @map("review") @db.VarChar(500)
    rating          Int       @map("rating") @db.Int
    ratedAt         DateTime  @default(now()) @map("rated_at")
    ratedBy         String    @map("rated_by") @db.VarChar(191)
    createdAt       DateTime  @default(now()) @map("created_at")
    updatedAt       DateTime? @updatedAt @map("updated_at")
    isActive        Boolean   @default(true) @map("is_active")

    doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

    @@index([rating], name: "idx_doctor_rating_rating")
    @@index([isActive, createdAt], name: "idx_doctor_rating_active_created")
    @@map("doctor_service_ratings")
}

model DoctorServiceLocation {
    id              String    @id @default(cuid()) @map("id") @db.VarChar(191)
    doctorProfileId String    @map("doctor_profile_id") @db.VarChar(191)
    location        String    @map("location") @db.VarChar(100)
    createdAt       DateTime  @default(now()) @map("created_at")
    updatedAt       DateTime? @updatedAt @map("updated_at")
    isActive        Boolean   @default(true) @map("is_active")

    doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

    @@index([location], name: "idx_doctor_service_location")
    @@index([isActive, createdAt], name: "idx_doctor_service_location_active_created")
    @@map("doctor_service_locations")
}

model DoctorAppointment {
    id              String    @id @default(cuid()) @map("id") @db.VarChar(191)
    appointmentId   String    @map("appointment_id") @db.VarChar(191)
    doctorId        String    @map("doctor_id") @db.VarChar(191)
    appointmentSlot DateTime? @map("appointment_slot") @db.DateTime
    status          String?   @map("status") @db.VarChar(100)
    createdAt       DateTime  @default(now()) @map("created_at")
    updatedAt       DateTime? @updatedAt @map("updated_at")
    isActive        Boolean   @default(true) @map("is_active")

    appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
    doctorProfile DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

    @@unique([appointmentId, doctorId, appointmentSlot], name: "uq_doctor_appointment")
    @@index([isActive, createdAt], name: "idx_doctor_appointment_active_created")
    @@map("doctor_appointments")
}
