model Appointment {
  id              String @id @default(cuid()) @map("id") @db.VarChar(191)
  userId          String @map("user_id") @db.VarChar(191)
  doctorProfileId String @map("doctor_profile_id") @db.VarChar(191)
  locationId      String @map("location_id") @db.VarChar(191)
  serviceId       String @map("service_id") @db.VarChar(191)

  appointmentDate DateTime @map("appointment_date") @db.Timestamp(6)
  status          String?  @map("status") @db.VarChar(100)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  //Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  location      Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  doctorRating    DoctorRating[]
  bookAppointment BookAppointment[]
  payment         Payment[]

  @@index([status(100)], name: "idx_appointment_status")
  @@index([appointmentDate(20)], name: "idx_appointment_date")
  @@map("appointments")
}

model BookAppointment {
  id            String @id @default(cuid()) @map("id") @db.VarChar(191)
  doctorId      String @map("doctor_id") @db.VarChar(191)
  locationId    String @map("location_id") @db.VarChar(191)
  appointmentId String @map("appointment_id") @db.VarChar(191)

  date      DateTime @map("date") @db.Timestamp(6)
  day       String?  @map("day") @db.VarChar(50)
  startTime String?  @map("start_time") @db.VarChar(50)
  endTime   String?  @map("end_time") @db.VarChar(50)
  status    String?  @map("status") @db.VarChar(100)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  //Relations
  doctor      User        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  location    Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status(100)], name: "idx_appointment_status")
  @@map("book_appointments")
}

model AppointmentSlot {
  id         String @id @default(cuid()) @map("id") @db.VarChar(191)
  doctorId   String @map("doctor_id") @db.VarChar(191)
  locationId String @map("location_id") @db.VarChar(191)

  day       String? @map("day") @db.VarChar(50)
  startTime String? @map("start_time") @db.VarChar(50)
  endTime   String? @map("end_time") @db.VarChar(50)

  appointmentSlotDuration Int? @map("appointment_slot_duration") @db.Int
  totalAppointmentSlots   Int? @map("total_appointment_slots") @db.Int

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  //Relations
  doctor   User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([appointmentSlotDuration], name: "idx_appointment_slot_duration")
  @@index([totalAppointmentSlots], name: "idx_total_appointment_slots")
  @@map("appointment_slots")
}

model Location {
  id       String  @id @default(cuid()) @map("id") @db.VarChar(191)
  doctorId String  @map("doctor_id") @db.VarChar(191)
  name     String  @map("name") @db.VarChar(100)
  address  String? @map("address") @db.VarChar(255)
  city     String? @map("city") @db.VarChar(100)
  state    String? @map("state") @db.VarChar(100)
  country  String? @map("country") @db.VarChar(100)
  zipCode  String? @map("zip_code") @db.VarChar(20)
  phone    String? @map("phone") @db.VarChar(20)

  isLocationVerified Boolean @default(false) @map("is_location_verified")
  verifiedBy         String? @map("verified_by") @db.VarChar(191)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  //Relations
  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  appointment     Appointment[]
  bookAppointment BookAppointment[]
  appointmentSlot AppointmentSlot[]
  service         Service[]

  @@index([isActive, createdAt], name: "idx_location_active_created")
  @@map("locations")
}

model Service {
  id         String @id @default(cuid()) @map("id") @db.VarChar(191)
  doctorId   String @map("doctor_id") @db.VarChar(191)
  locationId String @map("location_id") @db.VarChar(191)

  name        String  @unique @map("name") @db.VarChar(100)
  description String? @map("description") @db.VarChar(300)
  price       Decimal @map("price") @db.Decimal(10, 2)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  //Relations
  doctor   User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  appointment Appointment[]

  @@index([isActive, createdAt], name: "idx_appointment_active_created")
  @@map("service")
}

model Payment {
  id            String  @id @default(cuid()) @map("id") @db.VarChar(191)
  appointmentId String  @map("appointment_id") @db.VarChar(191)
  transactionId String? @map("transaction_id") @db.VarChar(191)

  amount Decimal @map("amount") @db.Decimal(10, 2)
  status String  @map("status") @db.VarChar(100)

  paymentMethod String  @map("payment_method") @db.VarChar(100)
  currencyCode  String? @map("currency_code") @db.VarChar(10)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  //Relations
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([amount(100)], name: "idx_users_payment_amount")
  @@index([status(100)], name: "idx_users_payment_status")
  @@index([paymentMethod(100)], name: "idx_users_payment_method")
  @@index([isActive, createdAt], name: "idx_users_active_created")
  @@map("payments")
}

model Specialization {
  id          String  @id @default(cuid()) @map("id") @db.VarChar(191)
  name        String  @map("name") @db.VarChar(100)
  description String? @map("description") @db.VarChar(255)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([name], name: "idx_specialization_name")
  @@map("specializations")
}

model DoctorProfile {
  id String @id @default(cuid()) @map("id") @db.VarChar(191)

  userId String @map("user_id") @db.VarChar(191)

  fullName        String  @map("full_name") @db.VarChar(200)
  bio             String? @map("bio") @db.VarChar(500)
  website         String? @map("website") @db.VarChar(200)
  overallRating   Decimal @map("overall_rating") @db.Decimal(2, 1)
  profileImageUrl String? @map("profile_image_url") @db.VarChar(255)
  documentUrl     String? @map("document_url") @db.VarChar(255)
  resumeUrl       String? @map("resume_url") @db.VarChar(255)

  isVerified Boolean @default(false) @map("is_verified")
  verifiedBy String? @map("verified_by") @db.VarChar(191)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointment          Appointment[]
  doctorSpecialization DoctorSpecialization[]
  doctorRating         DoctorRating[]

  @@index([overallRating], name: "idx_doctor_profile_overall_rating")
  @@index([isActive, createdAt], name: "idx_doctor_profile_active_created")
  @@map("doctor_profiles")
}

model DoctorSpecialization {
  id              String  @id @default(cuid()) @map("id") @db.VarChar(191)
  doctorProfileId String  @map("doctor_profile_id") @db.VarChar(191)
  specialization  String  @map("specialization") @db.VarChar(100)
  documentUrl     String? @map("document_url") @db.VarChar(255)

  isVerified Boolean @default(false) @map("is_verified")
  verifiedBy String? @map("verified_by") @db.VarChar(191)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  @@index([specialization], name: "idx_doctor_specialization")
  @@index([isActive, createdAt], name: "idx_doctor_specialization_active_created")
  @@map("doctor_service_specializations")
}

model DoctorRating {
  id              String @id @default(cuid()) @map("id") @db.VarChar(191)
  doctorId        String @map("doctor_id") @db.VarChar(191)
  doctorProfileId String @map("doctor_profile_id") @db.VarChar(191)
  appointmentId   String @map("appointment_id") @db.VarChar(191)

  review    String    @map("review") @db.VarChar(500)
  rating    Decimal   @map("rating") @db.Decimal(2, 1)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  isActive Boolean @default(true) @map("is_active")

  // Relations
  user          User          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([rating], name: "idx_doctor_rating_rating")
  @@index([isActive, createdAt], name: "idx_doctor_rating_active_created")
  @@map("doctor_service_ratings")
}

generator client {
  provider        = "prisma-client-js"
  output          = "../generated"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  FACEBOOK
  GITHUB
  APPLE
}

model User {
  id              String       @id @default(cuid()) @map("id") @db.VarChar(191) // UUID or cuid for unique user ID
  email           String       @unique @map("email") @db.VarChar(191) // RFC 5321 compliant
  passwordHash    String?      @map("password_hash") @db.VarChar(1000) // Sufficient for bcrypt hashes
  firstName       String?      @map("first_name") @db.VarChar(200)
  lastName        String?      @map("last_name") @db.VarChar(200)
  displayName     String?      @map("display_name") @db.VarChar(300)
  phoneNumber     String?      @map("phone_number") @db.VarChar(20) // E.164 format
  profileImageUrl String?      @map("profile_image_url") @db.VarChar(2048)
  provider        AuthProvider @default(CREDENTIALS) @map("provider")
  providerId      String?      @map("provider_id") @db.VarChar(100)
  isEmailVerified Boolean      @default(false) @map("is_email_verified")
  isPhoneVerified Boolean      @default(false) @map("is_phone_verified")
  isActive        Boolean      @default(true) @map("is_active")

  // Localization
  timezone String? @map("timezone") @db.VarChar(50) // IANA timezone format, e.g., "America/New_York"
  locale   String? @map("locale") @db.VarChar(10) // e.g., "en-US"

  // Extensibility
  metadata Json? @map("metadata") // For storing additional user preferences/data

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  roles            UserRole[]
  appointments     Appointment[]
  bookAppointments BookAppointment[]
  appointmentSlots AppointmentSlot[]
  locations        Location[]
  services         Service[]
  doctorProfiles   DoctorProfile[]
  doctorRatings    DoctorRating[]

  // Indexes for performance
  @@index([email(191)], name: "idx_users_email")
  @@index([phoneNumber(20)], name: "idx_users_phone_number")
  @@index([provider, providerId(100)], name: "idx_users_provider_provider_id")
  @@index([isActive, createdAt], name: "idx_users_active_created")
  @@index([provider, isEmailVerified], name: "idx_users_provider_verified")
  @@map("users")
}

model Role {
  id          String  @id @default(cuid()) @map("id") @db.VarChar(191) // UUID or cuid for unique role ID
  name        String  @unique @map("name") @db.VarChar(100)
  description String? @map("description") @db.VarChar(500)
  isActive    Boolean @default(true) @map("is_active")

  // Relations
  users UserRole[]

  // Indexes
  @@index([isActive], name: "idx_roles_active")
  @@map("roles")
}

model UserRole {
  userId String @map("user_id") @db.VarChar(191) // UUID or cuid for unique user ID
  roleId String @map("role_id") @db.VarChar(191) // UUID or cuid for unique role ID

  // Relations with cascade delete
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId], name: "idx_user_roles_user_id")
  @@index([roleId], name: "idx_user_roles_role_id")
  @@map("user_roles")
}
