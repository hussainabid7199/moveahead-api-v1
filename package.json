{
  "name": "nodejs_express_prisma",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "build": "tsc",
    "db:migrate:blank": "prisma migrate dev --create-only --name",
    "db:migrate": "prisma migrate dev --name ",
    "db:update": "prisma migrate dev",
    "db:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "schema": "./src/prisma/schema"
  },
  "keywords": [
    "node",
    "express",
    "prisma",
    "typescript",
    "MySQL"
  ],
  "author": "Abid Hussain",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.2.0",
    "@prisma/client": "^6.19.1",
    "bcrypt": "^5.1.1",
    "body-parser": "^2.2.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "inversify": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.11",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.19.3",
    "@types/nodemailer": "^7.0.4",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.10",
    "prisma": "^6.19.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
